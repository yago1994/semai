{
  "manifest_version": 3,
  "name": "remou",
  "version": "0.1",
  "description": "Transform clutter-filled Outlook Web email threads into a modern chat-like interface to streamline communication.",
  "icons": {
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": ["secrets.js", "semaiConfig.js", "contentScript.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*",
    "https://api.openai.com/*",
    "https://api.github.com/*"
  ]
}
